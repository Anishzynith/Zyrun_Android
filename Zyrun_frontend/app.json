{
  "expo": {
    "name": "ZYapp",
    "slug": "zyapp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/Firefly.png",
    "scheme": "zyapp",
    "extra": {
      "googleClientId": "1012302664400-6073m4mgphm1jtv0u10fc4sfff08ejoc.apps.googleusercontent.com",
      "googleWebClientId": "1012302664400-6073m4mgphm1jtv0u10fc4sfff08ejoc.apps.googleusercontent.com",
      "googleAndroidClientId": "1012302664400-ncmdep47qdvvh7eg8vrge88ak0qbcr79.apps.googleusercontent.com",
      "apiUrl": "http://192.168.88.7:8000/api/v1/auth",
      "router": {},
      "eas": {
        "projectId": "7f97b582-744b-411f-a413-bb494ec4bb68"
      }
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.zyapp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
